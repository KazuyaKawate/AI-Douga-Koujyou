# 一時ファイル
temp/
*.tmp
*.temp

# キャッシュ
__pycache__/
*.pyc
*.pyo
.cache/
.DS_Store
Thumbs.db

# 認証情報・設定ファイル（実値）
config/*.env
config/*.key
config/secrets.*
.env
.env.*
!.env.example

# 大容量メディアファイル（必要に応じてコメント解除）
# videos/
# voices/
# images/
# output/

# 素材ライブラリ — メディアファイルはローカルのみ、フォルダ構造は .gitkeep で管理
# (case-insensitive on Windows; patterns cover both lower and upper-case extensions)
assets/**/*.jpg
assets/**/*.jpeg
assets/**/*.png
assets/**/*.gif
assets/**/*.webp
assets/**/*.bmp
assets/**/*.psd
assets/**/*.mp4
assets/**/*.mov
assets/**/*.avi
assets/**/*.webm
assets/**/*.mp3
assets/**/*.wav
assets/**/*.ogg
assets/**/*.m4a
assets/**/*.aac
assets/**/*.flac

# プロジェクト生成ファイル（大容量になりうる）
project/

# OS・エディタ
.DS_Store
Desktop.ini
.idea/
.vscode/
*.swp
*.swo

# ログ
*.log
logs/

# Node.js（スクリプトでnpmを使う場合）
node_modules/
npm-debug.log*

# Python仮想環境（スクリプトでPythonを使う場合）
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Streamlit
.streamlit/secrets.toml

# Whisper モデルキャッシュ
*.pt

# バックアップ（ローカルのみ）
backups/
!backups/.gitkeep

# Claude Code ローカルメモリ（コミット不要）
.claude/
